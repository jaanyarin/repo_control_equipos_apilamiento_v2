{
  "expo": {
    "jsEngine": "hermes",
    "name": "Control de Equipos",
    "slug": "apilamiento-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "com.apilamiento",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.apilamiento.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1565C0"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "com.apilamiento",
              "host": "callback",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "09f4869d-8a0b-483e-b95b-c899fac76db1"
      }
    }
  }
}
